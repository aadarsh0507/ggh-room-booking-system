# Node dependencies (rebuilt inside Docker)
node_modules
frontend/node_modules
backend/node_modules

# Logs
*.log
logs/
npm-debug.log*

# Environment files (never bake secrets into the image)
.env
.env.*
backend/.env
backend/.env.*
frontend/.env
frontend/.env.*

# Build outputs (frontend is rebuilt in Stage 1)
frontend/build
backend/dist

# Test files
tests/
frontend/src/**/*.test.js
backend/tests/

# IDE / OS files
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Git
.git/
.gitignore
.gitattributes

# Docker files (not needed inside the image)
docker/
Dockerfile.*

# CI / scripts (not needed at runtime)
Jenkinsfile
*.ps1
*.bat

# Oracle client (must be mounted or installed separately if needed)
oracle-client/
oracle_tns/
