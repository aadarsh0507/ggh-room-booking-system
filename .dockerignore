# Node dependencies (rebuilt inside Docker)
node_modules
frontend/node_modules
backend/node_modules

# Logs
*.log
logs/
npm-debug.log*

# Environment files — exclude secrets, allow frontend build-time vars
.env
backend/.env
backend/.env.local
backend/.env.production
backend/.env.development
frontend/.env
frontend/.env.local
frontend/.env.development
frontend/.env.development.local
frontend/.env.production.local
# frontend/.env.production INTENTIONALLY NOT EXCLUDED — contains only
# REACT_APP_API_URL=/api (no secrets) needed by CRA at build time

# Build outputs (frontend is rebuilt in Stage 1)
frontend/build
backend/dist

# Test files
tests/
frontend/src/**/*.test.js
backend/tests/

# IDE / OS files
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Git
.git/
.gitignore
.gitattributes

# Docker files (not needed inside the image)
docker/
Dockerfile.*

# CI / scripts (not needed at runtime)
Jenkinsfile
*.ps1
*.bat

# Oracle client (must be mounted or installed separately if needed)
oracle-client/
oracle_tns/
